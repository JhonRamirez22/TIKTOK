# ═══════════════════════════════════════════════════
# KickClipBot — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ═══════════════════════════════════════════════════

# TikTok Credentials (usa las tuyas)
TIKTOK_EMAIL=tu_email@ejemplo.com
TIKTOK_PASSWORD=TuPasswordSeguro123

# TikTok API (opcional, si usas Content Posting API v2)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Kick (opcional, para clips autenticados)
KICK_AUTH_TOKEN=
KICK_XSRF_TOKEN=

# Whisper (opcional, modelo local por defecto)
# Si quieres usar OpenAI API para transcripción:
OPENAI_API_KEY=

# Proxy (opcional)
HTTP_PROXY=
HTTPS_PROXY=
